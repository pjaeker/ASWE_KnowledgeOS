{
  "allowedRepos": [
    "pjaeker/ASWE_KnowledgeOS"
  ],
  "allowedPaths": [
    "handbook/",
    "meta/",
    "decisions-adr/",
    "templates-harness/",
    "blackboard/",
    ".github/prompts/"
  ],
  "blockedPaths": [
    ".github/workflows/",
    "infra/",
    "secrets/",
    ".env",
    ".env.",
    "package-lock.json"
  ],
  "toolScopes": {
    "read_file": "mcp.read",
    "list_tree": "mcp.read",
    "create_branch": "mcp.write",
    "commit_files": "mcp.write",
    "open_pr": "mcp.write"
  },
  "scopeAliases": {
    "mcp": [
      "mcp.read",
      "mcp.write"
    ]
  },
  "maxFiles": 10,
  "maxDiffLines": 3000,
  "defaultBaseBranch": "main",
  "defaultDraftPr": true
}
