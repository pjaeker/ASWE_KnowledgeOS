PORT=3000
NODE_ENV=production
PUBLIC_BASE_URL=https://YOUR-DOMAIN

# Optional legacy fallback for non-OAuth MCP clients.
MCP_SHARED_SECRET=

# GitHub App credentials
GITHUB_APP_ID=
GITHUB_INSTALLATION_ID=
GITHUB_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# OAuth / OIDC bootstrap
OAUTH_DCR_ENABLED=true
OAUTH_DEV_SUBJECT=
OAUTH_DEFAULT_SCOPE=openid mcp
OAUTH_CODE_TTL_SECONDS=600
OAUTH_TOKEN_TTL_SECONDS=3600
# Optional. If omitted, the service generates an ephemeral RSA signing key at boot.
OAUTH_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Policy
POLICY_FILE=./policy.json
ALLOWED_REPOS=pjaeker/ASWE_KnowledgeOS
