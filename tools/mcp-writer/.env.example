PORT=3000
NODE_ENV=production
PUBLIC_BASE_URL=https://asweknowledgeos-production.up.railway.app
# Export these values into your shell/session. The Railway scripts read from
# process environment and pipe values to the CLI via stdin.

# Optional legacy fallback for non-OAuth MCP clients.
MCP_SHARED_SECRET=

# GitHub App credentials
GITHUB_APP_ID=
GITHUB_INSTALLATION_ID=
GITHUB_PRIVATE_KEY=REDACTED_PRIVATE_KEY_VALUE

# OAuth / OIDC bootstrap
OAUTH_DCR_ENABLED=true
OAUTH_DEV_SUBJECT=
OAUTH_DEFAULT_SCOPE=openid mcp.read
OAUTH_CODE_TTL_SECONDS=600
OAUTH_TOKEN_TTL_SECONDS=3600
# Optional dedicated signer. If omitted, OAuth falls back to GITHUB_PRIVATE_KEY for a restart-stable JWT/JWKS identity.
OAUTH_JWT_PRIVATE_KEY=REDACTED_JWT_SIGNING_KEY_VALUE

# Policy
POLICY_FILE=./policy.json
ALLOWED_REPOS=pjaeker/ASWE_KnowledgeOS
