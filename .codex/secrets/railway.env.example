# Copy this file to .codex/secrets/railway.env and fill locally.
# Do NOT commit the real file.

# Preferred: project-scoped Railway token for project-level CLI work
RAILWAY_TOKEN=

# Optional fallback: account/workspace-scoped token
# Only use if project token is not sufficient for the intended commands.
RAILWAY_API_TOKEN=

# Optional explicit target hints for local scripts
RAILWAY_PROJECT_NAME=
RAILWAY_ENVIRONMENT_NAME=
RAILWAY_SERVICE_NAME=
