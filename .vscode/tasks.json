{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Security: Scan Changed (OptionB)",
      "type": "shell",
      "command": "bash",
      "args": [
        "scripts/optionb/scan_incremental.sh",
        "--scope",
        "changed"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      }
    },
    {
      "label": "Security: Scan All (OptionB)",
      "type": "shell",
      "command": "bash",
      "args": [
        "scripts/optionb/scan_all.sh"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      }
    },
    {
      "label": "Security: Preflight",
      "type": "shell",
      "command": "bash",
      "args": [
        "scripts/optionb/preflight.sh"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false
      }
    },
    {
      "label": "Security: Repo Gates",
      "type": "shell",
      "command": "bash",
      "args": [
        "scripts/optionb/run_gates.sh"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false
      }
    },
    {
      "label": "ASWE: Bootstrap (Read Entry + Status + WS)",
      "type": "shell",
      "command": "python",
      "args": [
        "scripts/aswe_bootstrap.py",
        "--validate-session-contract"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      }
    },
    {
      "label": "ASWE: Validate Session Contract",
      "type": "shell",
      "command": "python",
      "args": [
        "scripts/validate_session_contract.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      }
    },
    {
      "label": "ASWE: Update Anchors",
      "type": "shell",
      "command": "python",
      "args": [
        "scripts/aswe_update_anchors.py",
        "--write"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      }
    },
    {
      "label": "ASWE: Preflight Changed Files",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "scripts/optionb/scan_incremental.sh --scope changed && scripts/optionb/preflight.sh && python scripts/validate_session_contract.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      }
    },
    {
      "label": "ASWE: Export Tooling Snapshot",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "RemoteSigned",
        "-File",
        "scripts/optionb/Export-ToolingSnapshot_V5.ps1",
        "-CodexConfigSource",
        "auto"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      }
    }
  ]
}
